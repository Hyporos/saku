# Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token

# MongoDB connection string
MONGO_URI=your_mongodb_connection_string

# Port the bot API server listens on (defaults to 25637 if not set)
PORT=25637

# Discord guild (server) ID
SAKU_GUILD_ID=your_guild_id

# Discord role IDs
BEE_ROLE_ID=720001044746076181
MEMBER_ROLE_ID=750000646345719899

# Shared secret for admin routes — every request proxied from the webapp carries this
# in the X-Admin-Secret header. Must match ADMIN_API_SECRET in apps/webapp/.env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_SECRET=generate_a_secure_random_string_here
